# Vercel AI Gateway
AI_GATEWAY_API_KEY=your-ai-gateway-api-key
# Vision model for image-based PDF analysis (provider/model format)
GOOGLE_VISION_MODEL=google/gemini-2.5-flash
ALIBABA_API_KEY=your-alibaba-api-key
ALIBABA_MODEL=qwen3.6-plus
ALIBABA_STRUCTURED_MODEL=qwen3-max
ALIBABA_FAST_MODEL=qwen-turbo
# Optional: custom endpoint / proxy
# ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DATABASE_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
QWEN_KEY=

# LiveKit Cloud — voice agent runtime
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Must match the agent_name registered by the Python worker (agent/src/agent.py)
AGENT_NAME=my-agent
NEXT_PUBLIC_AGENT_NAME=my-agent

NEXT_PUBLIC_ENABLE_VERCEL_ANALYTICS=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Required for event subscription decryption + signature verification.
# Configure these in the Feishu Developer Console under "Event Subscription".
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
